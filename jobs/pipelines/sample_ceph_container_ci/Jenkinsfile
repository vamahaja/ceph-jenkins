// Construct the Pulp RPM repository content URL for a given build
def get_pulp_repo_url(branch, sha1, distro, release, flavor) {
    return "${env.PULP_SERVER_URL}/pulp/content/repos/ceph/${branch}/${sha1}/${distro}/${release}/flavors/${flavor}/"
}

// Push a container image to the Pulp registry following official ceph-ci/ceph tag convention:
//   SHA1, BRANCH-SHORTSHA1-BASEOS-ARCH-devel, BRANCH
def publish_container_image() {
    def imageTag = "${DISTRO}-${RELEASE}-${ARCH}-${env.SHA1}"
    def shortSha = env.SHA1.take(7)
    def develTag = "${params.CEPH_BRANCH}-${shortSha}-${BASEOS}-${ARCH}-devel"
    def tags = [env.SHA1, develTag, params.CEPH_BRANCH]

    withCredentials([usernamePassword(
        credentialsId: "pulp-credentials",
        usernameVariable: "PULP_USER",
        passwordVariable: "PULP_PASS"
    )]) {
        tags.each { tag ->
            sh """
                sudo bash ${PULP_PUBLISH_IMAGE_SCRIPT} \
                    --image '${imageTag}' \
                    --registry '${PULP_SERVER_URL}' \
                    --base-path 'ceph-ci' \
                    --tag '${tag}' \
                    --username "\$PULP_USER" \
                    --password "\$PULP_PASS"
            """
        }
    }

    tags.each { tag ->
        echo "Published: ${PULP_SERVER_URL}/v2/ceph-ci/ceph:${tag}"
    }
}

pipeline {
    // Use jenkins server as the agent
    agent none

    options {
        // Keep the last 20 builds
        buildDiscarder(logRotator(numToKeepStr: "20"))

        // Do not checkout code automatically
        skipDefaultCheckout()

        // Timestamps in console output
        timestamps()

        // Colorize console output
        ansiColor("xterm")
    }

    environment {
        // Set shared workspace path
        SHARED_WS="/home/jenkins/workspace/${JOB_NAME}/${BUILD_NUMBER}"

        // Set up the environment variables that build_containe expects
        BUILD_CONTAINER_SCRIPT= "${SHARED_WS}/jobs/pipelines/sample_ceph_container_ci/build_container.sh"

        // Set up the Ceph directory
        CEPH_DIR="${SHARED_WS}/ceph"

        // Pulp project paths
        PULP_PROJECT_DIR="${SHARED_WS}/pulp-project"
        PULP_PUBLISH_IMAGE_SCRIPT="${PULP_PROJECT_DIR}/scripts/publish-image.sh"
    }

    stages {
        stage("Checkout Ceph Repository") {
            agent {
                node {
                    label "ceph-build-fedora39-agent"
                }
            }

            stages {
                stage("Checkout Pipeline Code") {
                    steps {
                        // Pull the Jenkinsfile repository
                        dir("${SHARED_WS}") {
                            checkout scm
                        }
                    }
                }

                stage("Checkout Pulp Project") {
                    steps {
                        // Clone the Pulp project repository
                        dir("${PULP_PROJECT_DIR}") {
                            checkout([
                                $class: "GitSCM",
                                branches: [[name: "main"]],
                                extensions: [
                                    [$class: "CloneOption", depth: 1,
                                        shallow: true, noTags: true]
                                ],
                                userRemoteConfigs: [
                                    [url: "${env.PULP_PROJECT_REPO}"]
                                ]
                            ])
                        }
                        sh "chmod +x ${PULP_PROJECT_DIR}/scripts/*.sh"
                    }
                }
            }
        }

        stage("Build Ceph Container Image") {
            parallel {
                stage("CentOS 9.Stream") {
                    when {
                        allOf {
                            expression {
                                return params.DISTRO.tokenize().contains("centos9")
                            }
                            expression {
                                return params.ARCH.tokenize().contains("x86_64")
                            }
                        }
                    }

                    agent {
                        node {
                            label "ceph-build-buildah-agent"
                        }
                    }

                    environment {
                        FROM_IMAGE="quay.io/centos/centos:stream9"
                        DISTRO="centos"
                        RELEASE="9"
                        ARCH="x86_64"
                        BASEOS="centos-stream9"
                    }

                    steps {
                        script {
                            echo "Running Buildah container image build script ..."

                            env.SHA1 = params.SHA1
                            env.VERSION = params.VERSION
                            env.REPO_URL = get_pulp_repo_url(
                                params.CEPH_BRANCH, env.SHA1, DISTRO, RELEASE, params.FLAVOR
                            )

                            dir("${CEPH_DIR}") {
                                sh "chmod +x ${BUILD_CONTAINER_SCRIPT} && ${BUILD_CONTAINER_SCRIPT}"
                            }

                            publish_container_image()
                        }
                    }
                }

                stage("Rocky Linux 10") {
                    when {
                        allOf {
                            expression {
                                return params.DISTRO.tokenize().contains("rocky10")
                            }
                            expression {
                                return params.ARCH.tokenize().contains("x86_64")
                            }
                        }
                    }

                    agent {
                        node {
                            label "ceph-build-buildah-agent"
                        }
                    }

                    environment {
                        FROM_IMAGE="docker.io/rockylinux/rockylinux:10"
                        DISTRO="rocky"
                        RELEASE="10"
                        ARCH="x86_64"
                        BASEOS="rocky-10"
                    }

                    steps {
                        script {
                            echo "Running Buildah container image build script ..."

                            env.SHA1 = params.SHA1
                            env.VERSION = params.VERSION
                            env.REPO_URL = get_pulp_repo_url(
                                params.CEPH_BRANCH, env.SHA1, DISTRO, RELEASE, params.FLAVOR
                            )

                            dir("${CEPH_DIR}") {
                                sh "chmod +x ${BUILD_CONTAINER_SCRIPT} && ${BUILD_CONTAINER_SCRIPT}"
                            }

                            publish_container_image()
                        }
                    }
                }
            }
        }
    }

    post {
        always {
            node("ceph-build-fedora39-agent") {
                ws("${SHARED_WS}") {
                    script {
                        echo "Cleaning up shared workspace ${SHARED_WS} ..."
                        cleanWs(disableDeferredWipeout: true, deleteDirs: true)
                    }
                }
            }
        }
    }
}
