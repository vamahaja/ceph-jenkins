FROM quay.io/rockylinux/rockylinux:10

# Define Build Arguments for UID/GID matching
ARG USER_ID=1000
ARG GROUP_ID=1000
ARG USER_NAME=jenkins

# Use baseurl instead of mirrorlist for Rocky repos
RUN sed -i 's/^mirrorlist=/#mirrorlist=/g' /etc/yum.repos.d/rocky*.repo && \
    sed -i 's|^#baseurl=http://dl.rockylinux.org/\$contentdir|baseurl=http://dl.rockylinux.org/pub/rocky|g' /etc/yum.repos.d/rocky*.repo

# Install all required RPM build tools and pipeline dependencies
RUN dnf install --allowerasing -y \
    sudo \
    java-21-openjdk-devel \
    git \
    rsync \
    which \
    rpm-build \
    dnf-plugins-core \
    yum-utils \
    python3-devel \
    python3-pip \
    python3-setuptools \
    gcc \
    gcc-c++ \
    make \
    cmake \
    cpio \
    jq \
    curl && \
    dnf clean all

# Enable CRB and EPEL repositories for Ceph build dependencies
RUN dnf -y install epel-release dnf-plugins-core && \
    /usr/bin/crb enable && \
    dnf -y install javapackages-tools python3-cython && \
    dnf clean all

# Build ragel from source and package as RPM (not available in EPEL 10)
RUN curl -sL https://www.colm.net/files/ragel/ragel-6.10.tar.gz | tar xz -C /tmp && \
    cd /tmp/ragel-6.10 && \
    ./configure --prefix=/usr && make -j$(nproc) && make install && \
    mkdir -p /tmp/ragel-rpm/{BUILD,RPMS,SOURCES,SPECS,SRPMS} && \
    printf '%s\n' \
      'Name: ragel' \
      'Version: 6.10' \
      'Release: 1%{?dist}' \
      'Summary: Finite state machine compiler' \
      'License: GPLv2' \
      '%description' \
      'Ragel compiles executable finite state machines from regular languages.' \
      '%install' \
      'mkdir -p %{buildroot}/usr/bin' \
      'cp /usr/bin/ragel %{buildroot}/usr/bin/' \
      '%files' \
      '/usr/bin/ragel' \
      > /tmp/ragel-rpm/SPECS/ragel.spec && \
    rpmbuild --define "_topdir /tmp/ragel-rpm" -bb /tmp/ragel-rpm/SPECS/ragel.spec && \
    rpm -i /tmp/ragel-rpm/RPMS/x86_64/ragel-*.rpm && \
    rm -rf /tmp/ragel-6.10 /tmp/ragel-rpm

# Create the Jenkins user and group to match the host
RUN groupadd -g ${GROUP_ID} ${USER_NAME} || true && \
    useradd -u ${USER_ID} -g ${GROUP_ID} -m ${USER_NAME} && \
    echo "${USER_NAME} ALL=(ALL) NOPASSWD: ALL" >> /etc/sudoers

# Set up the working directory and ownership
WORKDIR /home/${USER_NAME}
RUN chown -R ${USER_NAME}:${USER_NAME} /home/${USER_NAME}

# Switch to the non-root user
USER ${USER_NAME}

# The entrypoint remains a shell to allow the Jenkins script to run
CMD ["/bin/bash"]