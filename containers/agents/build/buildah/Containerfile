FROM quay.io/buildah/stable:latest

# Define Build Arguments for UID/GID matching
ARG USER_ID=1000
ARG GROUP_ID=1000
ARG USER_NAME=jenkins

# Install all required RPM build tools and pipeline dependencies
RUN dnf install --allowerasing -y java-21-openjdk-devel podman && \
    dnf clean all

# Create the Jenkins user and group (with root permissions via sudo)
RUN groupadd -g ${GROUP_ID} ${USER_NAME} || true && \
    useradd -u ${USER_ID} -g ${GROUP_ID} -m ${USER_NAME}

# Set root permissions for the Jenkins user
RUN echo "${USER_NAME} ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/${USER_NAME} && \
    chmod 440 /etc/sudoers.d/${USER_NAME}

# Set up the working directory and ownership
WORKDIR /home/${USER_NAME}
RUN chown -R ${USER_NAME}:${USER_NAME} /home/${USER_NAME}

# Switch to the non-root user
USER ${USER_NAME}

# The entrypoint remains a shell to allow the Jenkins script to run
CMD ["/bin/bash"]
